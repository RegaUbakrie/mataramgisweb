{
  "name": "mataram-webgis",
  "version": "1.0.0",
  "description": "WebGIS untuk Analisis Perubahan Vegetasi Kota Mataram 2024-2025",
  "author": "Kelompok 3 - Sistem Informasi Universitas Bakrie",
  "license": "MIT",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "powershell -File build-scripts/build.ps1 -Clean",
    "test": "npm run lint && npm run lighthouse",
    "lint": "eslint .",
    "lighthouse": "lighthouse https://localhost:3000 --view",
    "deploy": "npm run build && npm run test",
    "docker:build": "docker build -t mataram-webgis:1.0.0 .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "server:test": "curl -I http://localhost:3000"
  },
  "keywords": [
    "webgis",
    "mataram",
    "sentinel-2",
    "vegetation",
    "leaflet",
    "geojson"
  ],
  "dependencies": {
    "express": "^4.18.2",
    "compression": "^1.7.4",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "eslint": "^8.53.0",
    "lighthouse": "^11.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/mataram-webgis.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/mataram-webgis/issues"
  },
  "homepage": "https://github.com/yourusername/mataram-webgis#readme",
  "deployment": {
    "staging": "https://staging-mataram-webgis.example.com",
    "production": "https://mataram-webgis.example.com"
  }
}
